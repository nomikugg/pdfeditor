# Render Web Service environment variables for backend
# Required
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=pdf-files
PDFIUM_LIBRARY_PATH=/app/libpdfium.so
BIND_HOST=0.0.0.0

# Optional fallback local storage (used only if Supabase vars are missing)
FILES_ROOT=/var/data/files

# Optional logging
# PDF_VERBOSE_LOGS=false
